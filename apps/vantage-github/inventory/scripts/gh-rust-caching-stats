#!/usr/bin/env python3
"""GitHub Actions workflow/run/step helper for the vantage-github example.

Wraps the `gh` CLI. Actions:
  workflows [repo]                       List build workflows (pipelines) as JSON.
  runs <workflow_id> [repo] [--page N] [--success]
                                         List a workflow's runs (paginated).
  workflow-steps <workflow_id> [repo]    Canonical step list, taken from the
                                         workflow's latest successful run.
  run-steps <run_id> [repo]              Per-step durations (seconds) for one run,
                                         keyed by the same slug `scaffold-runs` uses
                                         for the table's column names.
  scaffold-runs <workflow_id> [repo] --name <label> --inventory <dir>
                                         Discover a workflow's steps and GENERATE a
                                         dedicated runs table + page whose columns are
                                         those steps, then register the page in
                                         menu/left.yaml. The running viewer hot-reloads
                                         the new files into the sidebar.

Repo defaults to romaninsh/vantage-ui. Step data comes from
`gh run view <run_id> --json jobs` (jobs[].steps[] with name + start/complete
timestamps); a step's duration is completedAt - startedAt.
"""

import glob
import json
import os
import re
import subprocess
import sys
import tempfile
from datetime import datetime

DEFAULT_REPO = "romaninsh/vantage-ui"


def gh(*args: str) -> subprocess.CompletedProcess:
    return subprocess.run(["gh", *args], capture_output=True, text=True)


def parse_iso(s: str) -> datetime:
    return datetime.fromisoformat(s.replace("Z", "+00:00"))


# ---------------------------------------------------------------------------
# Action: workflows
# ---------------------------------------------------------------------------
def cmd_workflows(repo: str, all_wf: bool = False) -> int:
    args = [
        "workflow", "list",
        "--repo", repo,
        "--json", "id,name,state,path",
        "--limit", "500",
    ]
    if all_wf:
        args.append("--all")
    r = gh(*args)
    if r.returncode != 0:
        sys.stderr.write(r.stderr)
        return r.returncode
    json.dump(json.loads(r.stdout), sys.stdout, indent=2)
    return 0


# ---------------------------------------------------------------------------
# Action: runs
# ---------------------------------------------------------------------------
def cmd_runs(workflow_id: str, repo: str, page: int = 1, per_page: int = 25,
             branch: str | None = None, not_branch: str | None = None,
             success_only: bool = False) -> int:
    args = [
        "api",
        f"repos/{repo}/actions/workflows/{workflow_id}/runs",
        "--method", "GET",
        "-f", f"per_page={per_page}",
        "-f", f"page={page}",
    ]
    if branch:
        args += ["-f", f"branch={branch}"]
    r = gh(*args)
    if r.returncode != 0:
        sys.stderr.write(r.stderr)
        return r.returncode
    data = json.loads(r.stdout)
    runs = []
    for run in data.get("workflow_runs", []):
        if not_branch and run["head_branch"] == not_branch:
            continue
        # Generated per-workflow tables list successful runs only — they're the
        # ones guaranteed to have executed every step (the table's column set).
        if success_only and (run.get("conclusion") or "") != "success":
            continue
        hc = run.get("head_commit", {})
        msg = hc.get("message", "")
        first_line = msg.split("\n")[0]
        pr_match = re.search(r"\(#(\d+)\)\s*$", first_line)
        runs.append({
            "run_id": run["id"],
            "run_number": run["run_number"],
            "workflow_id": int(workflow_id),
            "status": run["status"],
            "conclusion": run["conclusion"] or "",
            "event": run["event"],
            "display_title": run.get("display_title", ""),
            "head_branch": run["head_branch"],
            "head_sha": run.get("head_sha", "")[:8],
            "commit_message": first_line,
            "pr_number": int(pr_match.group(1)) if pr_match else None,
            "commit_author": hc.get("author", {}).get("name", ""),
            "triggering_actor": run.get("triggering_actor", {}).get("login", ""),
            "pull_requests": len(run.get("pull_requests", [])),
            "created_at": run["created_at"],
            "updated_at": run["updated_at"],
        })
    json.dump(runs, sys.stdout, indent=2)
    return 0


# ---------------------------------------------------------------------------
# Steps: shared helpers
# ---------------------------------------------------------------------------
def slugify(name: str) -> str:
    """A safe, stable column/key name for a step. Keyed by the step NAME (not
    its number) because step numbers shift between runs while names are stable —
    that's what lets a column line up across every run row."""
    s = re.sub(r"[^a-z0-9]+", "_", name.strip().lower()).strip("_")
    if not s:
        s = "step"
    if s[0].isdigit():
        s = "s_" + s
    return s


def _latest_successful_run(workflow_id: str, repo: str):
    r = gh(
        "run", "list",
        "--repo", repo,
        "--workflow", str(workflow_id),
        "--status", "success",
        "--limit", "1",
        "--json", "databaseId,number,headBranch,createdAt",
    )
    if r.returncode != 0:
        return None, (r.stderr.strip() or "gh run list failed")
    arr = json.loads(r.stdout)
    if not arr:
        return None, "no successful runs found"
    return arr[0], None


def _run_jobs(run_id: str, repo: str):
    r = gh("run", "view", str(run_id), "--repo", repo, "--json", "jobs")
    if r.returncode != 0:
        return None, (r.stderr.strip() or "gh run view failed")
    return json.loads(r.stdout).get("jobs", []), None


def _enumerate_steps(jobs: list) -> list:
    """Flatten jobs[].steps[] into an ordered list of step descriptors, each with
    a unique slug. Matrix runs (>1 job) namespace the slug by job so two jobs'
    same-named steps don't collide."""
    multi = len(jobs) > 1
    seen: dict = {}
    out = []
    for job in jobs:
        job_name = job.get("name", "job")
        jslug = slugify(job_name)
        for st in job.get("steps", []):
            name = st.get("name", "")
            slug = f"{jslug}__{slugify(name)}" if multi else slugify(name)
            n = seen.get(slug, 0) + 1
            seen[slug] = n
            if n > 1:
                slug = f"{slug}_{n}"
            out.append({
                "name": name,
                "slug": slug,
                "job": job_name,
                "started": st.get("startedAt"),
                "completed": st.get("completedAt"),
                "conclusion": st.get("conclusion"),
            })
    return out


def _duration_secs(start, end):
    if not start or not end:
        return None
    try:
        return int(round((parse_iso(end) - parse_iso(start)).total_seconds()))
    except Exception:
        return None


def _discover_steps(workflow_id: str, repo: str):
    """Return (steps, run, error) for the workflow's latest successful run."""
    run, err = _latest_successful_run(workflow_id, repo)
    if run is None:
        return [], None, err
    jobs, err = _run_jobs(run["databaseId"], repo)
    if jobs is None:
        return [], run, err
    return _enumerate_steps(jobs), run, None


# ---------------------------------------------------------------------------
# Action: workflow-steps  (augments the workflows table)
# ---------------------------------------------------------------------------
def cmd_workflow_steps(workflow_id: str, repo: str) -> int:
    steps, run, err = _discover_steps(workflow_id, repo)
    if err:
        # Degrade gracefully — the workflows table's steps cell just stays empty.
        sys.stderr.write(err + "\n")
    result = {
        "workflow_id": int(workflow_id),
        "run_id": run["databaseId"] if run else None,
        "run_number": run.get("number") if run else None,
        "step_count": len(steps),
        "steps": [{"name": s["name"], "slug": s["slug"]} for s in steps],
    }
    json.dump(result, sys.stdout, indent=2)
    return 0


# ---------------------------------------------------------------------------
# Action: run-steps  (per-run detail pass for a generated runs table)
# ---------------------------------------------------------------------------
def cmd_run_steps(run_id: str, repo: str) -> int:
    jobs, err = _run_jobs(run_id, repo)
    if jobs is None:
        sys.stderr.write(err + "\n")
        return 1
    out = {}
    for s in _enumerate_steps(jobs):
        secs = _duration_secs(s["started"], s["completed"])
        if secs is not None:
            out[s["slug"]] = secs
    json.dump(out, sys.stdout, indent=2)
    return 0


# ---------------------------------------------------------------------------
# Action: scaffold-runs — generate a per-workflow runs table + page + menu entry
# ---------------------------------------------------------------------------
def _yaml_dq(s: str) -> str:
    """Escape a string for a YAML double-quoted scalar."""
    return s.replace("\\", "\\\\").replace('"', '\\"')


def _atomic_write(path: str, content: str) -> None:
    """Write via temp + rename so the viewer's file watcher never reads a
    half-written YAML — a partial parse would surface as a transient error and
    leave the leaf stuck at its previous serial."""
    d = os.path.dirname(path) or "."
    os.makedirs(d, exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=d, suffix=".tmp")
    try:
        with os.fdopen(fd, "w") as f:
            f.write(content)
        os.replace(tmp, path)
    except BaseException:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


def _gen_table_yaml(name: str, workflow_id: str, repo: str, steps: list) -> str:
    out = [
        "# yaml-language-server: $schema=./table-schema-1.json",
        "# GENERATED by `gh-rust-caching-stats scaffold-runs` — do not hand-edit.",
        f"# Workflow {workflow_id} ({name}) on {repo}. The columns after",
        "# created_at are this workflow's steps (from its latest successful run);",
        "# each cell is that step's duration in seconds for the run on that row.",
        "datasource: gh-stats",
        f'title: "{_yaml_dq(name)} runs"',
        "columns:",
        "  - name: run_id",
        "    type: int",
        "    flags: [id]",
        "  - name: run_number",
        "    type: int",
        "  - name: head_branch",
        "    type: string",
        "    flags: [title]",
        "  - name: conclusion",
        "    type: string",
        "  - name: created_at",
        "    type: datetime",
    ]
    for s in steps:
        out.append(f"  # step: {s['name']}")
        out.append(f"  - name: {s['slug']}")
        out.append("    type: int")
    out += [
        "cmd:",
        "  # List pass: this workflow's successful runs (one cheap call). The",
        "  # workflow id + repo are baked in — this table is workflow-specific,",
        "  # so it needs no drill-down conditions.",
        "  rhai: |",
        f'    let out = run(["runs", "{workflow_id}", "{repo}", "--success"]);',
        "    if out.exit_code != 0 { throw out.stderr; }",
        "    parse_json(out.stdout)",
        "  # Detail pass: per-run step durations, keyed by the step slugs above.",
        "  detail: |",
        f'    let out = run(["run-steps", id.to_string(), "{repo}"]);',
        "    if out.exit_code != 0 { return [#{}]; }",
        "    [parse_json(out.stdout)]",
        "",
    ]
    return "\n".join(out)


def _gen_page_yaml(name: str, slug: str, workflow_id: str, step_slugs: list) -> str:
    # `step-slugs` is read back by the dashboard rebuilder to know this
    # table's stacked-area layers without re-parsing the table YAML.
    return (
        "# yaml-language-server: $schema=./page-schema-1.json\n"
        "# GENERATED by `gh-rust-caching-stats scaffold-runs` — do not hand-edit.\n"
        f"# Workflow {workflow_id} ({name}).\n"
        f"# menu-label: {name}\n"
        f"# step-slugs: {','.join(step_slugs)}\n"
        f'title: "{_yaml_dq(name)} runs"\n'
        "elements:\n"
        "  - kind: tableview\n"
        "    spot: body\n"
        f"    table: runs-{slug}\n"
    )


def _read_page_meta(page_path: str):
    """Return (menu_label, [step_slugs]) from a generated runs page's header
    comments. Both are written by `_gen_page_yaml`."""
    label, slugs = None, []
    try:
        with open(page_path) as f:
            for line in f:
                if line.startswith("# menu-label:"):
                    label = line.split(":", 1)[1].strip()
                elif line.startswith("# step-slugs:"):
                    slugs = [s for s in line.split(":", 1)[1].strip().split(",") if s]
                elif line.strip() and not line.startswith("#"):
                    break
    except OSError:
        pass
    return label, slugs


def _rebuild_dashboard(inventory: str) -> bool:
    """Regenerate page/dashboard.yaml from every generated runs page: one
    stacked-area chart per workflow (x = run number, layers = step seconds,
    no axis labels). Idempotent — rebuilt wholesale each call. Returns whether
    a dashboard exists afterwards."""
    page_dir = os.path.join(inventory, "page")
    dash_path = os.path.join(page_dir, "dashboard.yaml")

    entries = []
    for p in sorted(glob.glob(os.path.join(page_dir, "runs-*.yaml"))):
        stem = os.path.splitext(os.path.basename(p))[0]  # runs-<slug> == table key
        label, slugs = _read_page_meta(p)
        if slugs:
            entries.append((stem, label or stem, slugs))

    if not entries:
        if os.path.exists(dash_path):
            os.remove(dash_path)
        return False

    out = [
        "# yaml-language-server: $schema=./page-schema-1.json",
        "# GENERATED by `gh-rust-caching-stats scaffold-runs` — do not hand-edit.",
        "# One stacked-area chart per generated runs table:",
        "#   x = run number (one point per run), layers = steps (seconds),",
        "#   stacked to the total runtime. No axis labels — these are dense tiles.",
        "title: Dashboard",
        "layout: grid",
        "columns: 2",
        "elements:",
    ]
    for stem, label, slugs in entries:
        out.append("  - kind: chart")
        out.append("    spot: body")
        out.append(f"    table: {stem}")
        out.append("    chart_type: stacked_area")
        out.append("    x: run_number")
        out.append("    labels: false")
        out.append(f'    title: "{_yaml_dq(label)}"')
        out.append("    series:")
        for sl in slugs:
            out.append(f"      - {sl}")
    _atomic_write(dash_path, "\n".join(out) + "\n")
    return True


MENU_BEGIN = "# >>> scaffold-runs: generated workflow-run menu (do not edit) >>>"
MENU_END = "# <<< scaffold-runs <<<"

DEFAULT_MENU = (
    "# yaml-language-server: $schema=./menu-schema-1.json\n"
    "title: Vantage GitHub\n"
    "items:\n"
    "  - page: cache-efficiency\n"
    "    label: Cache Efficiency\n"
    "    icon: HardDrive\n"
)


def _menu_label(page_path: str, fallback: str) -> str:
    try:
        with open(page_path) as f:
            for line in f:
                if line.startswith("# menu-label:"):
                    return line.split(":", 1)[1].strip()
                if line.strip() and not line.startswith("#"):
                    break
    except OSError:
        pass
    return fallback


def _rebuild_menu(inventory: str) -> None:
    """Regenerate the 'Workflow Runs' menu section from every page/runs-*.yaml
    present. Idempotent and self-healing: re-running (or deleting a runs page)
    just reproduces the correct section. The static items above are untouched."""
    menu_path = os.path.join(inventory, "menu", "left.yaml")
    page_dir = os.path.join(inventory, "page")

    children = []
    for p in sorted(glob.glob(os.path.join(page_dir, "runs-*.yaml"))):
        stem = os.path.splitext(os.path.basename(p))[0]  # runs-<slug>
        children.append((stem, _menu_label(p, stem)))

    block_lines = [MENU_BEGIN]
    if os.path.exists(os.path.join(inventory, "page", "dashboard.yaml")):
        block_lines.append("  - page: dashboard")
        block_lines.append("    label: Dashboard")
        block_lines.append("    icon: LayoutDashboard")
    if children:
        block_lines.append("  - section: Workflow Runs")
        block_lines.append("    children:")
        for stem, label in children:
            block_lines.append(f"      - page: {stem}")
            block_lines.append(f'        label: "{_yaml_dq(label)}"')
            block_lines.append("        icon: Play")
    block_lines.append(MENU_END)
    block = "\n".join(block_lines)

    text = open(menu_path).read() if os.path.exists(menu_path) else DEFAULT_MENU

    # Strip any previously-generated block, then re-append the fresh one.
    text = re.sub(
        re.escape(MENU_BEGIN) + r".*?" + re.escape(MENU_END) + r"\n?",
        "", text, flags=re.DOTALL,
    ).rstrip() + "\n"

    _atomic_write(menu_path, text + block + "\n")


def cmd_scaffold_runs(workflow_id: str, repo: str, name: str, inventory: str) -> int:
    if not name:
        name = str(workflow_id)
    print(f"==> discovering steps for workflow {workflow_id} ({name}) on {repo}")
    steps, run, err = _discover_steps(workflow_id, repo)
    if err or not steps:
        sys.stderr.write(
            f"cannot scaffold: {err or 'latest successful run has no steps'}\n"
        )
        return 1
    print(f"    latest successful run #{run.get('number')} ({run['databaseId']}) "
          f"→ {len(steps)} steps:")
    for s in steps:
        print(f"      • {s['name']}  →  {s['slug']}")

    slug = slugify(name)
    table_path = os.path.join(inventory, "table", f"runs-{slug}.yaml")
    page_path = os.path.join(inventory, "page", f"runs-{slug}.yaml")

    step_slugs = [s["slug"] for s in steps]
    _atomic_write(table_path, _gen_table_yaml(name, workflow_id, repo, steps))
    print(f"==> wrote {table_path}")
    _atomic_write(page_path, _gen_page_yaml(name, slug, workflow_id, step_slugs))
    print(f"==> wrote {page_path}")
    # Dashboard first so the menu rebuild sees that dashboard.yaml exists.
    _rebuild_dashboard(inventory)
    print(f"==> rebuilt {os.path.join(inventory, 'page', 'dashboard.yaml')} "
          "(one stacked-area chart per workflow)")
    _rebuild_menu(inventory)
    print(f"==> updated {os.path.join(inventory, 'menu', 'left.yaml')} "
          "(Dashboard + section 'Workflow Runs')")
    print(f'\nDone. The viewer hot-reloads new inventory files — look for "{name}" '
          'under "Workflow Runs", and the stacked-runtime chart on "Dashboard".')
    return 0


# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------
def usage() -> int:
    sys.stderr.write(
        "usage: gh-rust-caching-stats <action> [args...]\n"
        "  workflows [repo]\n"
        "  runs <workflow_id> [repo] [--page N] [--success]\n"
        "  workflow-steps <workflow_id> [repo]\n"
        "  run-steps <run_id> [repo]\n"
        "  scaffold-runs <workflow_id> [repo] --name <label> --inventory <dir>\n"
    )
    return 2


def main(argv: list) -> int:
    if not argv:
        return usage()

    action = argv[0]
    rest = argv[1:]

    if action == "workflows":
        repo = DEFAULT_REPO
        all_wf = False
        for a in rest:
            if a == "--all":
                all_wf = True
            else:
                repo = a
        return cmd_workflows(repo, all_wf)

    if action == "runs":
        if not rest:
            sys.stderr.write("runs requires <workflow_id>\n")
            return 2
        workflow_id = rest[0]
        repo = DEFAULT_REPO
        page = 1
        per_page = 25
        branch = None
        not_branch = None
        success_only = False
        i = 1
        while i < len(rest):
            if rest[i] == "--page" and i + 1 < len(rest):
                page = int(rest[i + 1]); i += 2
            elif rest[i] == "--per-page" and i + 1 < len(rest):
                per_page = int(rest[i + 1]); i += 2
            elif rest[i] == "--branch" and i + 1 < len(rest):
                branch = rest[i + 1]; i += 2
            elif rest[i] == "--not-branch" and i + 1 < len(rest):
                not_branch = rest[i + 1]; i += 2
            elif rest[i] == "--success":
                success_only = True; i += 1
            else:
                repo = rest[i]; i += 1
        return cmd_runs(workflow_id, repo, page, per_page,
                        branch=branch, not_branch=not_branch,
                        success_only=success_only)

    if action == "workflow-steps":
        if not rest:
            sys.stderr.write("workflow-steps requires <workflow_id>\n")
            return 2
        workflow_id = rest[0]
        repo = rest[1] if len(rest) > 1 else DEFAULT_REPO
        return cmd_workflow_steps(workflow_id, repo)

    if action == "run-steps":
        if not rest:
            sys.stderr.write("run-steps requires <run_id>\n")
            return 2
        run_id = rest[0]
        repo = rest[1] if len(rest) > 1 else DEFAULT_REPO
        return cmd_run_steps(run_id, repo)

    if action == "scaffold-runs":
        if not rest:
            sys.stderr.write("scaffold-runs requires <workflow_id>\n")
            return 2
        workflow_id = rest[0]
        repo = DEFAULT_REPO
        name = ""
        inventory = "."
        i = 1
        while i < len(rest):
            if rest[i] == "--name" and i + 1 < len(rest):
                name = rest[i + 1]; i += 2
            elif rest[i] == "--inventory" and i + 1 < len(rest):
                inventory = rest[i + 1]; i += 2
            else:
                repo = rest[i]; i += 1
        return cmd_scaffold_runs(workflow_id, repo, name, inventory)

    return usage()


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))

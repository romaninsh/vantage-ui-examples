#!/usr/bin/env python3
"""Generic GitHub Actions cache/compile stats helper.

Wraps `gh` CLI. Actions:
  workflows [repo]                       List workflows as YAML.
  analyze <workflow_id> [repo]           Estimate the full crate count from recent runs.
  runs <workflow_id> [repo] [--page N]   List runs (paginated).
  stats <run_id> [repo] [--total-crates N]  Get cache stats for one run.

Repo defaults to romaninsh/vantage-ui.

Cache/compile signals are detected by unique log markers (Cache Size, Restored
from cache key, Saving cache, Compiling) — no jobs API, no step numbers, no
timestamps. The only cross-run parameter is total_crates, the fullest (cold)
build's crate count, which `stats` divides into per-run compiles for the
cache-effectiveness percentage.
"""

import json
import re
import subprocess
import sys



DEFAULT_REPO = "romaninsh/vantage-ui"

ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")


def gh(*args: str) -> subprocess.CompletedProcess:
    return subprocess.run(["gh", *args], capture_output=True, text=True)


def strip_ansi(text: str) -> str:
    return ANSI_RE.sub("", text)


# ---------------------------------------------------------------------------
# Action: workflows
# ---------------------------------------------------------------------------
def cmd_workflows(repo: str, all_wf: bool = False) -> int:
    args = [
        "workflow", "list",
        "--repo", repo,
        "--json", "id,name,state,path",
        "--limit", "500",
    ]
    if all_wf:
        args.append("--all")
    r = gh(*args)
    if r.returncode != 0:
        sys.stderr.write(r.stderr)
        return r.returncode
    json.dump(json.loads(r.stdout), sys.stdout, indent=2)
    return 0


# ---------------------------------------------------------------------------
# Action: analyze
# ---------------------------------------------------------------------------
from datetime import datetime

ANALYZE_RUN_LIMIT = 30      # successful runs to consider as candidates


def parse_iso(s: str) -> datetime:
    return datetime.fromisoformat(s.replace("Z", "+00:00"))


def iter_log_lines(stdout: str):
    """Yield the ANSI-stripped content of each `gh run view --log` line.

    Each line is `job \\t step-name \\t timestamp content`; we only need the
    content payload, where the unique cache/compile markers live."""
    for raw_line in stdout.splitlines():
        parts = raw_line.split("\t", 2)
        if len(parts) < 3:
            continue
        yield strip_ansi(parts[2])


def _count_crates(run_id: str, repo: str):
    """Download one run's log and count `Compiling` lines (its crate count).

    Returns the count, or None if the log is unavailable (e.g. HTTP 410
    expired) so the caller can skip the run. No jobs API call — the log is
    the only thing we need."""
    log_r = gh("run", "view", str(run_id), "--repo", repo, "--log")
    if log_r.returncode != 0:
        sys.stderr.write(log_r.stderr)
        return None
    return sum(1 for content in iter_log_lines(log_r.stdout)
               if re.search(r"\bCompiling\b", content))


def cmd_analyze(workflow_id: str, repo: str) -> int:
    """Estimate the full crate count by sampling runs across the duration range.

    `stats` computes cache_effective_pct as 1 - compiled/total_crates, so
    total_crates must be the fullest (cold) build's crate count. The cold build
    is the long-running one, so we sample three runs spread across the duration
    range — shortest, median, longest — and take the MAX `Compiling` count.
    Sampling the spread (not just the longest) guards against a duration
    outlier and against any one log being expired (410)."""
    r = gh(
        "run", "list",
        "--repo", repo,
        "--workflow", str(workflow_id),
        "--limit", str(ANALYZE_RUN_LIMIT),
        "--json", "databaseId,number,conclusion,createdAt,updatedAt",
    )
    if r.returncode != 0:
        sys.stderr.write(r.stderr)
        return r.returncode

    successful = [run for run in json.loads(r.stdout) if run["conclusion"] == "success"]
    if not successful:
        sys.stderr.write("no successful runs found\n")
        return 1

    for run in successful:
        run["_dur"] = (parse_iso(run["updatedAt"]) - parse_iso(run["createdAt"])).total_seconds()
    successful.sort(key=lambda x: x["_dur"])

    shortest = successful[0]
    longest = successful[-1]
    median = successful[len(successful) // 2]

    # Dedup while keeping longest first (its crate count is the fullest build).
    picks = []
    for run in (longest, median, shortest):
        if all(run["databaseId"] != p["databaseId"] for p in picks):
            picks.append(run)

    total_crates = 0
    representative = None     # run that yielded the most crates (fullest build)
    scanned = 0

    for run in picks:
        crates = _count_crates(run["databaseId"], repo)
        if crates is None:
            continue  # log unavailable (410 etc.) — skip this sample
        scanned += 1
        if crates > total_crates or representative is None:
            total_crates = max(total_crates, crates)
            representative = run
        sys.stderr.write(
            f"scanned run #{run['number']} ({run['_dur']:.0f}s): crates={crates}\n"
        )

    if representative is None:
        sys.stderr.write("no usable run logs (all expired or empty)\n")
        return 1

    result = {
        "workflow_id": int(workflow_id),
        "run_id": representative["databaseId"],
        "run_number": representative["number"],
        "runs_scanned": scanned,
        "total_crates": total_crates,
    }
    json.dump(result, sys.stdout, indent=2)
    return 0


# ---------------------------------------------------------------------------
# Action: runs
# ---------------------------------------------------------------------------
def cmd_runs(workflow_id: str, repo: str, page: int = 1, per_page: int = 25,
            branch: str | None = None, not_branch: str | None = None) -> int:
    args = [
        "api",
        f"repos/{repo}/actions/workflows/{workflow_id}/runs",
        "--method", "GET",
        "-f", f"per_page={per_page}",
        "-f", f"page={page}",
    ]
    if branch:
        args += ["-f", f"branch={branch}"]
    r = gh(*args)
    if r.returncode != 0:
        sys.stderr.write(r.stderr)
        return r.returncode
    data = json.loads(r.stdout)
    runs = []
    for run in data.get("workflow_runs", []):
        if not_branch and run["head_branch"] == not_branch:
            continue
        hc = run.get("head_commit", {})
        msg = hc.get("message", "")
        first_line = msg.split("\n")[0]
        pr_match = re.search(r"\(#(\d+)\)\s*$", first_line)
        runs.append({
            "run_id": run["id"],
            "run_number": run["run_number"],
            "workflow_id": int(workflow_id),
            "status": run["status"],
            "conclusion": run["conclusion"] or "",
            "event": run["event"],
            "display_title": run.get("display_title", ""),
            "head_branch": run["head_branch"],
            "head_sha": run.get("head_sha", "")[:8],
            "commit_message": first_line,
            "pr_number": int(pr_match.group(1)) if pr_match else None,
            "commit_author": hc.get("author", {}).get("name", ""),
            "triggering_actor": run.get("triggering_actor", {}).get("login", ""),
            "pull_requests": len(run.get("pull_requests", [])),
            "created_at": run["created_at"],
            "updated_at": run["updated_at"],
        })
    json.dump(runs, sys.stdout, indent=2)
    return 0


# ---------------------------------------------------------------------------
# Action: stats
# ---------------------------------------------------------------------------
def _split_cache_key(key: str) -> tuple:
    parts = key.split("-")
    if len(parts) >= 2:
        return parts[-2], parts[-1]
    return "", ""


def cmd_stats(run_id: str, repo: str, total_crates: int = 0) -> int:
    # The log carries every signal; no jobs API / step filtering needed.
    log_r = gh("run", "view", str(run_id), "--repo", repo, "--log")
    if log_r.returncode != 0:
        sys.stderr.write(log_r.stderr)
        return log_r.returncode

    cache_size = ""
    cache_match = ""
    cache_key = ""
    env_hash = ""
    lock_hash = ""
    build_time = ""
    crates_compiled = 0

    for content in iter_log_lines(log_r.stdout):
        # First "Cache Size:" is the restore (it precedes any save in the log).
        if not cache_size and "Cache Size: " in content:
            after = content.split("Cache Size: ", 1)[1]
            cache_size = after.split(" (", 1)[0].strip()

        if "Restored from cache key" in content:
            m2 = re.search(r'Restored from cache key "([^"]+)"', content)
            if m2:
                cache_key = m2.group(1)
                env_hash, lock_hash = _split_cache_key(cache_key)
            if "full match: " in content:
                cache_match = "full" if "full match: true" in content else "partial"

        if "`dev` profile" in content or "`release` profile" in content:
            if " in " in content and "Finished" in content:
                build_time = content.rsplit(" in ", 1)[1].strip()

        if re.search(r"\bCompiling\b", content):
            crates_compiled += 1

    cache_effective_pct = (
        round((1 - crates_compiled / total_crates) * 100)
        if total_crates > 0 and crates_compiled > 0 else None
    )

    result = {
        "run_id": int(run_id),
        "cache_size": cache_size,
        "cache_match": cache_match,
        "cache_key": cache_key,
        "env_hash": env_hash,
        "lock_hash": lock_hash,
        "compile_time": build_time,
        "compiled_crates": crates_compiled,
        "cache_effective_pct": cache_effective_pct,
    }
    json.dump(result, sys.stdout, indent=2)
    return 0


# ---------------------------------------------------------------------------
# Action: pr-diff
# ---------------------------------------------------------------------------
def cmd_pr_diff(pr_number: int | None, branch: str | None, repo: str) -> int:
    if not pr_number and not branch:
        sys.stderr.write("pr-diff requires --pr <number> or --branch <name>\n")
        return 2

    # If branch given, find the PR
    if branch and not pr_number:
        owner = repo.split("/")[0]
        r = gh("api", f"repos/{repo}/pulls?head={owner}:{branch}&state=all", "--jq", ".[0].number")
        if r.returncode != 0 or not r.stdout.strip():
            sys.stderr.write(f"no PR found for branch {branch}\n")
            return 1
        pr_number = int(r.stdout.strip())

    r = gh("api", f"repos/{repo}/pulls/{pr_number}")
    if r.returncode != 0:
        sys.stderr.write(r.stderr)
        return r.returncode
    pr = json.loads(r.stdout)

    result = {
        "pr_number": pr["number"],
        "title": pr["title"],
        "state": pr["state"],
        "user": pr.get("user", {}).get("login", ""),
        "additions": pr["additions"],
        "deletions": pr["deletions"],
        "changed_files": pr["changed_files"],
        "merged": pr.get("merged", False),
        "base_branch": pr["base"]["ref"],
        "head_branch": pr["head"]["ref"],
    }
    json.dump(result, sys.stdout, indent=2)
    return 0


# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------
def usage() -> int:
    sys.stderr.write(
        "usage: gh-rust-caching-stats <action> [args...]\n"
        "  workflows [repo]\n"
        "  analyze <workflow_id> [repo]\n"
        "  runs <workflow_id> [repo] [--page N]\n"
        "  stats <run_id> [repo] [--total-crates N]\n"
    )
    return 2


def main(argv: list) -> int:
    if not argv:
        return usage()

    action = argv[0]
    rest = argv[1:]

    if action == "workflows":
        repo = DEFAULT_REPO
        all_wf = False
        i = 0
        while i < len(rest):
            if rest[i] == "--all":
                all_wf = True
            else:
                repo = rest[i]
            i += 1
        return cmd_workflows(repo, all_wf)

    if action == "analyze":
        if not rest:
            sys.stderr.write("analyze requires <workflow_id>\n")
            return 2
        workflow_id = rest[0]
        repo = rest[1] if len(rest) > 1 else DEFAULT_REPO
        return cmd_analyze(workflow_id, repo)

    if action == "runs":
        if not rest:
            sys.stderr.write("runs requires <workflow_id>\n")
            return 2
        workflow_id = rest[0]
        repo = DEFAULT_REPO
        page = 1
        branch = None
        not_branch = None
        i = 1
        while i < len(rest):
            if rest[i] == "--page" and i + 1 < len(rest):
                page = int(rest[i + 1])
                i += 2
            elif rest[i] == "--branch" and i + 1 < len(rest):
                branch = rest[i + 1]
                i += 2
            elif rest[i] == "--not-branch" and i + 1 < len(rest):
                not_branch = rest[i + 1]
                i += 2
            elif rest[i] == "--per-page" and i + 1 < len(rest):
                i += 2
            else:
                repo = rest[i]
                i += 1
        return cmd_runs(workflow_id, repo, page, branch=branch, not_branch=not_branch)

    if action == "stats":
        if not rest:
            sys.stderr.write("stats requires <run_id>\n")
            return 2
        run_id = rest[0]
        repo = DEFAULT_REPO
        total_crates = 0
        i = 1
        while i < len(rest):
            if rest[i] == "--total-crates" and i + 1 < len(rest):
                total_crates = int(rest[i + 1])
                i += 2
            else:
                repo = rest[i]
                i += 1
        return cmd_stats(run_id, repo, total_crates)

    if action == "pr-diff":
        repo = DEFAULT_REPO
        pr_number = None
        branch = None
        i = 0
        while i < len(rest):
            if rest[i] == "--pr" and i + 1 < len(rest):
                pr_number = int(rest[i + 1])
                i += 2
            elif rest[i] == "--branch" and i + 1 < len(rest):
                branch = rest[i + 1]
                i += 2
            else:
                repo = rest[i]
                i += 1
        return cmd_pr_diff(pr_number, branch, repo)

    return usage()


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
